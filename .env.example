# Real LLM / browser-use configuration for testhub_ai_agent_learning.
# Copy this file to .env and fill in your own values.
# Do NOT commit .env with real secrets.

# Required for real LLM mode.
OPENAI_API_KEY=sk-your-api-key-here

# Optional. Leave empty to use the SDK default OpenAI endpoint.
# For OpenAI-compatible providers, set a /v1 endpoint, for example:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_BASE_URL=

# Optional model/provider labels.
OPENAI_MODEL=gpt-4o-mini
OPENAI_PROVIDER=openai
OPENAI_TEMPERATURE=0

# Browser execution options.
# true: run headless; false: show browser window.
BROWSER_HEADLESS=true

# Optional proxy environment variables, if your network requires them.
# The project includes socksio in the real extra so SOCKS proxies can work.
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890
